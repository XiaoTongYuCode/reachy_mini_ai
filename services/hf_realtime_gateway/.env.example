# Bind to 127.0.0.1 for same-machine usage. Use 0.0.0.0 when Reachy Mini
# connects over the LAN.
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8765

# Chinese-first local STT defaults. The default avoids running STT and Qwen3
# TTS on MLX at the same time, which can crash Metal on some Apple Silicon Macs.
GATEWAY_STT=faster-whisper
GATEWAY_STT_MODEL=large-v3
GATEWAY_FASTER_WHISPER_STT_DEVICE=auto
GATEWAY_FASTER_WHISPER_STT_COMPUTE_TYPE=auto
GATEWAY_LANGUAGE=zh

# OpenAI-compatible external LLM endpoint.
GATEWAY_LLM_BASE_URL=http://127.0.0.1:8000/v1
GATEWAY_LLM_API_KEY=
GATEWAY_LLM_MODEL=

# Chinese-first local TTS defaults.
GATEWAY_TTS=qwen3
GATEWAY_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
GATEWAY_TTS_SPEAKER=Vivian
GATEWAY_TTS_LANGUAGE=Chinese
GATEWAY_QWEN3_TTS_MLX_QUANTIZATION=6bit

# Advanced toggles.
GATEWAY_RESPONSES_API_STREAM=true
GATEWAY_ENABLE_LIVE_TRANSCRIPTION=true
GATEWAY_SPEECH_TO_SPEECH_BIN=speech-to-speech
