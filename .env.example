# === 1. Realtime 后端选择 ===
# 可选值："huggingface"（默认）、"openai"、"gemini"、"ark"。
BACKEND_PROVIDER="huggingface"

# === 2. 本地 Hugging Face 连接 ===
# 使用本机 gateway 时启用；不配置时默认使用内置 Hugging Face server。
# HF_REALTIME_CONNECTION_MODE="local"
# HF_REALTIME_WS_URL="ws://127.0.0.1:8765/v1/realtime"
# HF_REALTIME_AUTO_START=true
# HF_REALTIME_AUTO_START_TIMEOUT_SECONDS=600

# === 3. 云端后端凭据与模型覆盖 ===
# 只有选择对应后端时才需要填写对应 key。
OPENAI_API_KEY=
# GEMINI_API_KEY=
# MODEL_NAME="gpt-realtime"

# === 3b. 火山引擎 Realtime 语音对话 ===
# BACKEND_PROVIDER=ark 时使用火山引擎官方二进制 websocket 协议。
# ARK_REALTIME_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
# ARK_REALTIME_APP_ID=
# ARK_REALTIME_ACCESS_KEY=
# ARK_REALTIME_APP_KEY=
# ARK_REALTIME_RESOURCE_ID=volc.speech.dialog
# ARK_REALTIME_BOT_NAME=Reachy Mini

# === 4. 本地 gateway 的 LLM 配置 ===
# HF_REALTIME_AUTO_START=true 时通常需要填写。
# STT/TTS、端口、VAD、缓存等已有代码默认值；只有确实要覆盖时再添加。
GATEWAY_LLM_BASE_URL=http://127.0.0.1:8000/v1
GATEWAY_LLM_API_KEY=
GATEWAY_LLM_MODEL=

# 兼容接口不支持 provider-side thinking 参数时，可显式覆盖。
# GATEWAY_RESPONSES_API_DISABLE_THINKING=false

# === 5. Hugging Face / 本地视觉可选项 ===
# HF_TOKEN=
# HF_HOME=./cache
# LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct

# === 6. 工具：火山引擎 Web Search ===
# VOLCENGINE_WEB_SEARCH_API_KEY=
# VOLCENGINE_WEB_SEARCH_API_URL=https://open.feedcoopapi.com/search_api/web_search
# VOLCENGINE_WEB_SEARCH_TIMEOUT_SECONDS=30

# === 7. 天气：WeatherAPI.com ===
# 前往 https://www.weatherapi.com/signup.aspx 注册并获取免费 API Key。
# WEATHERAPI_API_KEY=

# === 8. 工具：SMTP 邮件发送 ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your.sender@gmail.com
# SMTP_PASSWORD=your-16-character-app-password
# SMTP_FROM_EMAIL=your.sender@gmail.com
# SMTP_FROM_NAME=Reachy Mini
# SMTP_USE_SSL=false
# SMTP_USE_TLS=true
# default_target_email=recipient@example.com

# === 9. Profile 与外部工具 ===
# REACHY_MINI_CUSTOM_PROFILE=mars_rover
# REACHY_MINI_EXTERNAL_PROFILES_DIRECTORY=external_content/external_profiles
# REACHY_MINI_EXTERNAL_TOOLS_DIRECTORY=external_content/external_tools
# AUTOLOAD_EXTERNAL_TOOLS=1
