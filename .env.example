# Realtime 后端选择："pipeline"、"huggingface"、"openai" 或 "gemini"。
# 推荐自建低成本语音流水线时使用 "pipeline"：
# - STT/TTS 由 services/hf_realtime_gateway 本地运行；
# - LLM 由该 gateway 调用 OpenAI 兼容接口，例如 OpenRouter；
# - 当前 App 仍然只连接本机 OpenAI Realtime 兼容 websocket。
BACKEND_PROVIDER="huggingface"

# 自建流水线的本地 realtime websocket。
# 如果不填写，pipeline 后端默认连接 ws://127.0.0.1:8765/v1/realtime。
# PIPELINE_REALTIME_WS_URL="ws://127.0.0.1:8765/v1/realtime"

# 自建流水线的 LLM 摘要配置，供 App/UI 判断 pipeline 是否已配置。
# 真正启动 gateway 时，实际 LLM/STT/TTS 配置来自 services/hf_realtime_gateway/.env。
# 使用 OpenRouter 时可参考：
PIPELINE_LLM_PROVIDER=openai
PIPELINE_LLM_BASE_URL=https://openrouter.ai/api/v1
PIPELINE_LLM_MODEL=z-ai/glm-4.5-air:free
# 不建议在根 .env 重复保存密钥；把实际 key 放在 services/hf_realtime_gateway/.env 的 GATEWAY_LLM_API_KEY。
# PIPELINE_LLM_API_KEY=

# 旧的 Hugging Face websocket 路线。如果你不使用 pipeline，而是直接连接 HF gateway，
# 可以改为 BACKEND_PROVIDER="huggingface" 并配置下面几项。
# HF_REALTIME_CONNECTION_MODE="local"
# HF_REALTIME_WS_URL="ws://127.0.0.1:8765/v1/realtime"
# HF_REALTIME_AUTO_START=true
# HF_REALTIME_AUTO_START_TIMEOUT_SECONDS=600
# HF_REALTIME_LANGUAGE="zh"

# OpenAI Realtime / Gemini Live 路线使用的模型覆盖项。
# Hugging Face 和 pipeline 的模型主要由各自 gateway 决定。
# MODEL_NAME="gpt-realtime"

# 云端后端 API key。只有选择对应后端时才需要。
OPENAI_API_KEY=
# GEMINI_API_KEY=

# 本地视觉模型，仅在使用 --local-vision CLI 参数时生效。
# 默认情况下，相机工具的视觉理解由当前 realtime 后端处理。
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct

# 本地 VLM / Hugging Face 缓存目录。
HF_HOME=./cache

# Hugging Face token，用于访问受限模型或数据集；公开模型可留空。
HF_TOKEN=

# 火山引擎 Web Search 产品 API 配置。
# 只有使用 web_search 工具时才需要 VOLCENGINE_WEB_SEARCH_API_KEY。
# 默认 URL 使用 APIKey 接入点，不是 Ark Responses 插件。
# VOLCENGINE_WEB_SEARCH_API_KEY=
# VOLCENGINE_WEB_SEARCH_API_URL=https://open.feedcoopapi.com/search_api/web_search
# VOLCENGINE_WEB_SEARCH_TIMEOUT_SECONDS=30

# 邮件发送工具的 SMTP 配置。
# Gmail 可使用 smtp.gmail.com:587 和 Google 应用专用密码。
# 不要填写普通 Gmail 登录密码。
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your.sender@gmail.com
# SMTP_PASSWORD=your-16-character-app-password
# SMTP_FROM_EMAIL=your.sender@gmail.com
# SMTP_FROM_NAME=Reachy Mini
# SMTP_USE_SSL=false
# SMTP_USE_TLS=true
# default_target_email=recipient@example.com

# 可选：内置 profile 选择器。填写 profiles/ 下的文件夹名。
# 留空时使用默认 profile，除非 UI 的启动设置里保存了其他选择。
# REACHY_MINI_CUSTOM_PROFILE=mars_rover

# 可选：外部 profile / tool 目录。
# REACHY_MINI_EXTERNAL_PROFILES_DIRECTORY=external_content/external_profiles
# REACHY_MINI_EXTERNAL_TOOLS_DIRECTORY=external_content/external_tools

# 可选：自动发现并加载 REACHY_MINI_EXTERNAL_TOOLS_DIRECTORY 下的所有工具，
# 即使它们没有写在当前 profile 的 tools.txt 中。
# 适合把下载的工具临时叠加到默认 profile 上。
# AUTOLOAD_EXTERNAL_TOOLS=1
